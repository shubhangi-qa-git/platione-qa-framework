# QA environment configuration
TEST_ENV=qa
BASE_URL=http://qa.plati-one.local
API_URL=http://qa.plati-one.local/api
TEST_USER=qa.user@plati-one.com
TEST_PASSWORD=Password123!

# When true (default), API clients return mock responses instead of real HTTP.
# Set to false once the QA backend is reachable.
MOCK_API=true

# Database (used by DB seeder / DbUtil)
DB_HOST=localhost
DB_PORT=3306
DB_USER=qa_user
DB_PASSWORD=qa_password
DB_NAME=platione_qa
